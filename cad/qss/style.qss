QPushButton.bla {
    background-color: #CCCCCC;
    color: #666666;
    border: 2px solid #AAAAAA;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 10px;
}
QPushButton.bla:hover {
    background-color: #DDDDDD;
    border-color: #999999;
}
QPushButton.bla:pressed {
    background-color: #BBBBBB;
    border-color: #888888;
}

